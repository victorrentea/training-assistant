#!/bin/sh
set -e

# Keep deploy-info in the same commit to avoid a follow-up bot commit/deploy.
python3 scripts/generate_deploy_info.py
git add static/deploy-info.json

# work-hours.js is maintained manually by the project owner.
# Keep this hook lean: deploy-info generation + Python method-size enforcement.
python3 scripts/check_python_method_length.py \
  --max-lines 60 \
  --baseline scripts/python_method_length_baseline.json \
  --staged
