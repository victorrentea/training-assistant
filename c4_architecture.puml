@startuml C1_SystemContext
!include <C4/C4_Context>

title Workshop Live Interaction Tool — C1: System Context

LAYOUT_WITH_LEGEND()

Person(host, "Host", "Facilitator running the session.\nUses the host panel to manage polls,\nreview quiz previews, and monitor participants.")
Person(participant, "Participant", "Audience member joining via browser.\nVotes on polls, sees live results.\nNo install or account required.")
Person(victor, "Victor (Trainer)", "Runs quiz_daemon.py on his Mac.\nTriggers AI quiz generation from\ntranscription files.")

System(workshop, "Workshop Tool", "Self-hosted real-time audience\ninteraction platform.\nFastAPI + WebSocket backend,\nvanilla JS frontend.")

System_Ext(claude_api, "Anthropic Claude API", "LLM API used to generate\ndebate-triggering poll questions\nfrom workshop transcripts.")
System_Ext(nominatim, "Nominatim (OpenStreetMap)", "Reverse geocoding API.\nConverts GPS coordinates to\ncity + country strings.")
System_Ext(browser_apis, "Browser APIs", "Geolocation API, localStorage,\nnative WebSocket client.\nUsed by participant pages.")

Rel(host, workshop, "Manages polls and quiz preview", "HTTPS / WebSocket (Basic Auth)")
Rel(participant, workshop, "Joins session, votes on polls", "HTTPS / WebSocket (no auth)")
Rel(victor, workshop, "Runs daemon, triggers quiz generation", "HTTPS REST (Basic Auth, on Mac)")
Rel(workshop, claude_api, "Generates quiz questions from transcript", "HTTPS REST (Anthropic SDK)")
Rel(participant, nominatim, "Resolves GPS to city/country", "HTTPS REST (from browser)")
Rel(participant, browser_apis, "Geolocation, localStorage, WebSocket", "Browser-internal")

@enduml

newpage

@startuml C2_Containers
!include <C4/C4_Container>

title Workshop Live Interaction Tool — C2: Container Diagram

LAYOUT_WITH_LEGEND()

Person(host, "Host", "Facilitator")
Person(participant, "Participant", "Audience member")
Person(victor, "Victor (Trainer)", "Runs daemon on Mac")

System_Ext(claude_api, "Anthropic Claude API", "LLM quiz generation")
System_Ext(nominatim, "Nominatim", "Reverse geocoding")

System_Boundary(workshop, "Workshop Tool") {

    Container(caddy, "Caddy Reverse Proxy", "Caddy (single binary)", "Terminates TLS (Let's Encrypt).\nEnforces HTTP Basic Auth on\n/host, /api/poll, /api/poll/status,\n/api/quiz-*.\nForwards to FastAPI on :8000.")

    Container(fastapi, "FastAPI Backend", "Python 3.9 / FastAPI / Uvicorn\n(port 8000, 127.0.0.1)", "All business logic.\nREST endpoints + WebSocket.\nServes static HTML/JS/CSS.\nRuns as systemd workshop.service.")

    Container(appstate, "In-Memory AppState", "Python singleton (dict)\nno database", "Single-room session model.\nHolds poll, votes, scores,\nparticipant WebSocket refs,\nlocations, quiz pipeline state.\nCleared on server restart.")

    Container(static_files, "Static Files", "HTML / Vanilla JS / CSS\n(served by FastAPI /static)", "participant.html + participant.js\nhost.html + host.js\ncommon.css, participant.css, host.css")

    Container(quiz_daemon, "Quiz Daemon", "Python 3.12 CLI\n(trainer's Mac)", "Long-running background process.\nPolls /api/quiz-request every 1s.\nLoads local .txt/.vtt/.srt transcript.\nCalls Claude API to generate questions.\nPosts preview to backend.")
}

Rel(host, caddy, "Opens host panel, manages polls", "HTTPS :443")
Rel(participant, caddy, "Opens participant page, votes", "HTTPS :443 / WSS")
Rel(victor, quiz_daemon, "Starts/stops daemon process", "Local terminal")
Rel(caddy, fastapi, "Proxies all requests", "HTTP :8000")
Rel(fastapi, appstate, "Reads and mutates session state", "In-process Python call")
Rel(fastapi, static_files, "Serves HTML/JS/CSS files", "FileResponse / StaticFiles mount")
Rel(quiz_daemon, caddy, "Polls for requests, posts quiz preview", "HTTPS REST (Basic Auth)")
Rel(quiz_daemon, claude_api, "Generates quiz from transcript text", "HTTPS REST (Anthropic SDK)")
Rel(participant, nominatim, "Reverse geocodes GPS", "HTTPS REST (browser fetch)")

@enduml

newpage

@startuml C3_Components
!include <C4/C4_Component>

title Workshop Live Interaction Tool — C3: Component Diagram (FastAPI Backend)

LAYOUT_WITH_LEGEND()

Person(host, "Host", "Facilitator")
Person(participant, "Participant", "Audience member")
Container_Ext(quiz_daemon, "Quiz Daemon", "Python CLI on trainer's Mac")
Container_Ext(caddy, "Caddy", "Reverse proxy / TLS termination")

Container_Boundary(fastapi, "FastAPI Backend") {

    Component(pages_router, "pages.py", "FastAPI APIRouter", "Serves static HTML pages.\nGET / → participant.html\nGET /host → host.html")

    Component(ws_router, "routers/ws.py", "FastAPI APIRouter\nWebSocket endpoint", "WS /ws/{participant_name}\nHandles: connect, disconnect,\nvote (single), multi_vote,\nlocation message.\nBroadcasts vote_update and\nparticipant_count to all peers.")

    Component(poll_router, "routers/poll.py", "FastAPI APIRouter\nREST endpoints", "POST /api/poll — create poll\nPOST /api/poll/status — open/close\nPOST /api/poll/correct — score + reveal\nPOST /api/poll/timer — countdown\nDELETE /api/poll — clear poll\nGET /api/suggest-name — LOTR name\nGET /api/status — public summary")

    Component(scores_router, "routers/scores.py", "FastAPI APIRouter\nREST endpoint", "DELETE /api/scores\nResets scores and base_scores,\nbroadcasts empty scores message.")

    Component(quiz_router, "routers/quiz.py", "FastAPI APIRouter\nREST endpoints", "POST /api/quiz-request — host triggers AI gen\nGET /api/quiz-request — daemon polls (clears)\nPOST /api/quiz-status — daemon reports progress\nPOST /api/quiz-preview — daemon posts result\nDELETE /api/quiz-preview — host clears preview\nPOST /api/quiz-refine — host requests regen\nGET /api/quiz-refine — daemon polls (clears)")

    Component(state_module, "state.py", "Python module\nAppState singleton", "AppState class: poll, poll_active,\nvotes, participants (name→WebSocket),\nsuggested_names, locations, scores,\nbase_scores, vote_times, poll_opened_at,\nquiz_request, quiz_refine_request,\nquiz_status, quiz_preview,\ndaemon_last_seen.\nMethods: suggest_name(), vote_counts()")

    Component(messaging_module, "messaging.py", "Python module\nasync helpers", "build_state_message() — assembles\nfull state snapshot dict including\ndaemon_connected heartbeat check.\nbroadcast(msg, exclude) — sends JSON\nto all connected WebSockets.\nsend_state_to(ws) — sends state\nsnapshot to a single client.")
}

Rel(caddy, pages_router, "GET /, GET /host", "HTTP (proxied)")
Rel(caddy, ws_router, "WS /ws/{name}", "WebSocket upgrade (proxied)")
Rel(caddy, poll_router, "POST/DELETE /api/poll, /api/suggest-name", "HTTP (proxied)")
Rel(caddy, scores_router, "DELETE /api/scores", "HTTP (proxied, Basic Auth)")
Rel(caddy, quiz_router, "POST/GET/DELETE /api/quiz-*", "HTTP (proxied, Basic Auth)")

Rel(ws_router, state_module, "Registers/removes participants,\nrecords votes and locations")
Rel(ws_router, messaging_module, "broadcast(), send_state_to()")
Rel(poll_router, state_module, "Creates/clears poll,\ncalculates scores")
Rel(poll_router, messaging_module, "broadcast(), build_state_message()")
Rel(scores_router, state_module, "Clears scores and base_scores")
Rel(scores_router, messaging_module, "broadcast()")
Rel(quiz_router, state_module, "Stores quiz_request, quiz_preview,\nrefine_request, daemon_last_seen")
Rel(quiz_router, messaging_module, "broadcast() quiz_status + quiz_preview")

Rel(participant, caddy, "Connects WS, votes, sends location", "WSS / HTTPS")
Rel(host, caddy, "Creates polls, opens/closes,\nsets correct options, resets scores", "HTTPS (Basic Auth)")
Rel(quiz_daemon, caddy, "Polls quiz-request, posts quiz-preview,\nposts quiz-status, polls quiz-refine", "HTTPS (Basic Auth)")

@enduml
