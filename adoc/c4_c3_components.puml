' DEPRECATED: replaced by c3_backend.puml, c3_host_daemon.puml, c3_desktop_overlay.puml

@startuml C3_Components
!include <C4/C4_Component>

title Workshop Live Interaction Tool — C3: Component Diagram (FastAPI Backend)

LAYOUT_WITH_LEGEND()

Container_Ext(participant_spa, "Participant SPA", "Vanilla JS in trainee's browser.")
Container_Ext(host_spa, "Host SPA", "Vanilla JS in host's browser.")
Container_Ext(training_daemon, "Training Daemon", "Python CLI on host's Mac.")
Container_Ext(emoji_overlay, "Emoji Overlay", "Swift app on host's Mac.")

Container_Boundary(fastapi, "FastAPI Backend") {

    Component(main_module, "main.py", "FastAPI app entry", "Mounts all routers.\nPOST /api/mode")

    Component(pages_router, "pages.py", "FastAPI APIRouter", "GET / → participant.html\nGET /host → host.html\nGET /notes")

    Component(ws_router, "routers/ws.py", "FastAPI APIRouter", "WS /ws/{uuid}\nHandles set_name, vote, multi_vote,\nlocation, wordcloud_word, qa_submit, qa_upvote,\ndebate_pick_side, debate_argument,\ndebate_upvote, debate_volunteer,\ncodereview_select, codereview_deselect,\nemoji_reaction, refresh_avatar.\nPersonalized state broadcast per client.")

    Component(poll_router, "routers/poll.py", "FastAPI APIRouter", "POST /api/poll\nPUT /api/poll/status\nPUT /api/poll/correct\nPOST /api/poll/timer\nDELETE /api/poll\nGET /api/suggest-name\nGET /api/status")

    Component(activity_router, "routers/activity.py", "FastAPI APIRouter", "POST /api/activity\nSwitch activity type.")

    Component(wordcloud_router, "routers/wordcloud.py", "FastAPI APIRouter", "POST /api/wordcloud/topic\nPOST /api/wordcloud/clear")

    Component(qa_router, "routers/qa.py", "FastAPI APIRouter", "PUT /api/qa/question/{id}/text\nDELETE /api/qa/question/{id}\nPUT /api/qa/question/{id}/answered\nPOST /api/qa/clear")

    Component(codereview_router, "routers/codereview.py", "FastAPI APIRouter", "POST /api/codereview\nPUT /api/codereview/status\nPUT /api/codereview/confirm-line\nDELETE /api/codereview")

    Component(debate_router, "routers/debate.py", "FastAPI APIRouter", "POST /api/debate\nPOST /api/debate/reset\nPOST /api/debate/close-selection\nPOST /api/debate/force-assign\nPOST /api/debate/phase\nPOST /api/debate/first-side\nPOST /api/debate/round-timer\nPOST /api/debate/end-round\nPOST /api/debate/end-arguments\nGET /api/debate/ai-request\nPOST /api/debate/ai-result")

    Component(scores_router, "routers/scores.py", "FastAPI APIRouter", "DELETE /api/scores")

    Component(leaderboard_router, "routers/leaderboard.py", "FastAPI APIRouter", "POST /api/leaderboard/show\nPOST /api/leaderboard/hide")

    Component(quiz_router, "routers/quiz.py", "FastAPI APIRouter", "POST/GET /api/quiz-request\nPOST /api/quiz-status\nPOST/DELETE /api/quiz-preview\nPOST/GET /api/quiz-refine")

    Component(summary_router, "routers/summary.py", "FastAPI APIRouter", "POST /api/summary\nGET /api/summary\nPOST /api/notes\nGET /api/notes\nPOST /api/transcript-status\nPOST /api/summary/force\nGET /api/summary/force\nPOST /api/token-usage")

    Component(state_module, "state.py", "AppState singleton", "All dicts UUID-keyed.\nPoll: poll, votes, poll_opened_at, poll_correct_ids\nParticipants: names, avatars, locations, scores\nActivities: current_activity, wordcloud, qa, codereview\nDebate: statement, phase, sides, arguments,\nchampions, auto_assigned, rounds, ai_request\nDaemon: quiz_request/status/preview, daemon_last_seen\nSummary: summary_points, notes_content\nTranscript: line_count, total_lines, latest_ts\nOther: mode, token_usage, leaderboard_active")

    Component(messaging_module, "messaging.py", "Async helpers", "broadcast_state()\nsend_state_to_participant()\nsend_state_to_host()\nbroadcast_leaderboard()\nsend_emoji_to_overlay()\nsend_emoji_to_host()\n_build_debate_for_participant()\n_build_debate_for_host()")

    Component(persist_db, "persistence/db.py", "DB connection", "get_connection()\nSQLite3 WAL mode,\nRow factory.")

    Component(persist_migrate, "persistence/migrate.py", "Schema migrations", "run_migrations()\nApplies SQL files from migrations/\nin version order.")

    Component(persist_snapshot, "persistence/snapshot.py", "Periodic snapshots", "write_snapshot()\nstart_snapshot_loop()\nWrites participants, scores,\nactivity state every 2s.")

    Component(persist_restore, "persistence/restore.py", "State restore", "restore_state()\nLoads participants, scores, mode,\nand activity state from SQLite\non startup.")

    Component(persist_serializers, "persistence/serializers.py", "Serialization helpers", "serialize_activity_state()\nrestore_activity_state()\nConverts sets, datetimes, enums\nto/from JSON strings.")
}

ContainerDb_Ext(sqlite_db, "SQLite Database", "data/state.db")

' --- External → FastAPI relationships ---
Rel(participant_spa, ws_router, "Connect WS, vote, location, debate, codereview", "WSS")
Rel(participant_spa, pages_router, "GET /", "HTTPS")
Rel(participant_spa, poll_router, "GET /api/status, /api/suggest-name", "HTTPS")

Rel(host_spa, ws_router, "Host WS connection", "WSS (Basic Auth)")
Rel(host_spa, pages_router, "GET /host, GET /notes", "HTTPS (Basic Auth)")
Rel(host_spa, poll_router, "Manage polls", "HTTPS (Basic Auth)")
Rel(host_spa, activity_router, "Switch activity", "HTTPS (Basic Auth)")
Rel(host_spa, wordcloud_router, "Word cloud lifecycle", "HTTPS (Basic Auth)")
Rel(host_spa, qa_router, "Manage Q&A", "HTTPS (Basic Auth)")
Rel(host_spa, codereview_router, "Code review lifecycle", "HTTPS (Basic Auth)")
Rel(host_spa, debate_router, "Manage debate", "HTTPS (Basic Auth)")
Rel(host_spa, scores_router, "Reset scores", "HTTPS (Basic Auth)")
Rel(host_spa, leaderboard_router, "Show/hide leaderboard", "HTTPS (Basic Auth)")
Rel(host_spa, summary_router, "Summary, notes, transcript", "HTTPS (Basic Auth)")

Rel(training_daemon, quiz_router, "Quiz pipeline", "HTTPS (Basic Auth)")
Rel(training_daemon, summary_router, "Summary, transcript status", "HTTPS (Basic Auth)")
Rel(training_daemon, poll_router, "Post polls", "HTTPS (Basic Auth)")

Rel(emoji_overlay, ws_router, "WS /ws/__overlay__ (emoji reactions)", "WSS")

' --- Internal component relationships ---
Rel(ws_router, state_module, "Participants, votes, locations, debate, codereview")
Rel(ws_router, messaging_module, "broadcast_state(), send_state_to_participant()")
Rel(poll_router, state_module, "Poll lifecycle, scoring")
Rel(poll_router, messaging_module, "broadcast_state()")
Rel(activity_router, state_module, "Switch current_activity")
Rel(activity_router, messaging_module, "broadcast_state()")
Rel(wordcloud_router, state_module, "Word cloud lifecycle")
Rel(wordcloud_router, messaging_module, "broadcast_state()")
Rel(qa_router, state_module, "Q&A questions lifecycle")
Rel(qa_router, messaging_module, "broadcast_state()")
Rel(codereview_router, state_module, "Code review lifecycle, selections, confirmed lines")
Rel(codereview_router, messaging_module, "broadcast_state()")
Rel(debate_router, state_module, "Debate lifecycle, sides, arguments, rounds")
Rel(debate_router, messaging_module, "broadcast_state()")
Rel(scores_router, state_module, "Reset scores")
Rel(scores_router, messaging_module, "broadcast_state()")
Rel(leaderboard_router, state_module, "Leaderboard visibility")
Rel(leaderboard_router, messaging_module, "broadcast_leaderboard()")
Rel(quiz_router, state_module, "Quiz pipeline state")
Rel(quiz_router, messaging_module, "broadcast_state()")
Rel(summary_router, state_module, "Summary points, notes, transcript, token usage")
Rel(summary_router, messaging_module, "broadcast_state()")

' --- Persistence relationships ---
Rel(main_module, persist_migrate, "run_migrations() on startup")
Rel(main_module, persist_restore, "restore_state() on startup")
Rel(main_module, persist_snapshot, "start_snapshot_loop() on startup")
Rel(persist_snapshot, state_module, "Reads AppState for snapshotting")
Rel(persist_snapshot, persist_serializers, "serialize_activity_state()")
Rel(persist_snapshot, persist_db, "get_connection()")
Rel(persist_restore, state_module, "Writes to AppState on restore")
Rel(persist_restore, persist_serializers, "restore_activity_state()")
Rel(persist_restore, persist_db, "get_connection()")
Rel(persist_migrate, persist_db, "get_connection()")
Rel(persist_db, sqlite_db, "File I/O", "SQLite3")

@enduml
