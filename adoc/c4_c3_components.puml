@startuml C3_Components
!include <C4/C4_Component>

title Workshop Live Interaction Tool — C3: Component Diagram (FastAPI Backend)

LAYOUT_WITH_LEGEND()

Container_Ext(participant_spa, "Participant SPA", "Vanilla JS in trainee's browser.")
Container_Ext(host_spa, "Host SPA", "Vanilla JS in host's browser.")
Container_Ext(quiz_daemon, "Quiz Daemon", "Python CLI on host's Mac.")
Container_Ext(caddy, "Caddy", "Reverse proxy / TLS termination.")

Container_Boundary(fastapi, "FastAPI Backend") {

    Component(pages_router, "pages.py", "FastAPI APIRouter", "GET / → participant.html\nGET /host → host.html")

    Component(ws_router, "routers/ws.py", "FastAPI APIRouter", "WS /ws/{participant_name}\nHandles connect, vote, multi_vote,\nlocation, wordcloud_word.\nBroadcasts state updates to all peers.")

    Component(poll_router, "routers/poll.py", "FastAPI APIRouter", "POST /api/poll\nPOST /api/poll/status\nPOST /api/poll/correct\nPOST /api/poll/timer\nDELETE /api/poll\nGET /api/suggest-name\nGET /api/status")

    Component(wordcloud_router, "routers/wordcloud.py", "FastAPI APIRouter", "POST /api/wordcloud\nPOST /api/wordcloud/status\nDELETE /api/wordcloud")

    Component(scores_router, "routers/scores.py", "FastAPI APIRouter", "DELETE /api/scores")

    Component(quiz_router, "routers/quiz.py", "FastAPI APIRouter", "POST/GET /api/quiz-request\nPOST /api/quiz-status\nPOST/DELETE /api/quiz-preview\nPOST/GET /api/quiz-refine")

    Component(summary_router, "routers/summary.py", "FastAPI APIRouter", "POST /api/summary\nStores key points, broadcasts to all.")

    Component(state_module, "state.py", "AppState singleton", "poll, poll_active, votes,\nparticipants, locations, scores,\nbase_scores, vote_times,\ncurrent_activity, wordcloud_words,\nquiz_request, quiz_preview,\ndaemon_last_seen, summary_points.")

    Component(messaging_module, "messaging.py", "Async helpers", "build_state_message()\nbroadcast(msg, exclude)\nsend_state_to(ws)")
}

Rel(caddy, pages_router, "GET /, GET /host", "HTTP")
Rel(caddy, ws_router, "WS /ws/{name}", "WebSocket")
Rel(caddy, poll_router, "/api/poll*, /api/suggest-name", "HTTP")
Rel(caddy, scores_router, "DELETE /api/scores", "HTTP (Basic Auth)")
Rel(caddy, quiz_router, "/api/quiz-*", "HTTP (Basic Auth)")
Rel(caddy, wordcloud_router, "/api/wordcloud/status", "HTTP (Basic Auth)")

Rel(ws_router, state_module, "Participants, votes, locations")
Rel(ws_router, messaging_module, "broadcast(), send_state_to()")
Rel(poll_router, state_module, "Poll lifecycle, scoring")
Rel(poll_router, messaging_module, "broadcast()")
Rel(scores_router, state_module, "Reset scores")
Rel(scores_router, messaging_module, "broadcast()")
Rel(quiz_router, state_module, "Quiz pipeline state")
Rel(quiz_router, messaging_module, "broadcast()")
Rel(wordcloud_router, state_module, "Word cloud lifecycle")
Rel(wordcloud_router, messaging_module, "broadcast()")

Rel(participant_spa, caddy, "Vote, connect WS, send location", "WSS / HTTPS")
Rel(host_spa, caddy, "Manage polls, mark correct, reset scores", "HTTPS / WSS (Basic Auth)")
Rel(caddy, summary_router, "/api/summary", "HTTP (Basic Auth)")
Rel(summary_router, state_module, "Summary points")
Rel(summary_router, messaging_module, "broadcast()")

Rel(quiz_daemon, caddy, "Poll requests, post preview, status, summary", "HTTPS (Basic Auth)")

@enduml
