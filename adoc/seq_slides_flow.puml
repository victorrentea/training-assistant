@startuml seq_slides_flow
title Slides Catalog Flow - Participant View and Host Upload

actor       "Host" as Host
participant "Host UI\n(host.js)" as HostUI
participant "Backend\n(FastAPI)" as Backend
participant "Slides Router\n(routers/slides.py)" as Slides
participant "Uploaded Store\n(.context/uploaded-slides)" as UploadStore
participant "Local Materials\n(materials/slides)" as LocalStore
participant "Daemon State\n(state.slides/slides_current)" as DaemonState
participant "Participant UI\n(participant.js)" as PaxUI
actor       "Participant" as Pax

== Optional Bootstrap on Production (host-only) ==

Host -> HostUI : Select PDF file
HostUI -> Backend : POST /api/slides/upload (multipart)
Backend -> Slides : upload_slide_pdf(file, slug?, name?)
Slides -> UploadStore : write <slug>.pdf + <slug>.json
Slides --> HostUI : 200 {ok:true, slide:{slug,url,name}}

note right of Backend
  /api/slides/upload is protected
  by host auth (require_host_auth)
end note

== Participant Opens Slides Modal ==

Pax -> PaxUI : Click "Slides"
PaxUI -> Backend : GET /api/slides
Backend -> Slides : get_slides()

par Gather source A
  Slides -> UploadStore : index uploaded PDFs
  UploadStore --> Slides : uploaded_slides[]
else Gather source B
  Slides -> LocalStore : scan materials/slides
  LocalStore --> Slides : local_slides[]
else Gather source C
  Slides -> DaemonState : read state.slides + slides_current
  DaemonState --> Slides : state_slides[]
end

Slides -> Slides : _merge_slide_sources(uploaded, local, state)
Slides --> PaxUI : 200 {slides:[...]}

alt slides list is empty
  PaxUI -> Pax : show "No slides published yet"
else slides list has entries
  PaxUI -> Pax : fill combo box with slide names
  PaxUI -> Backend : GET /api/slides/file/{slug}
  Backend -> Slides : get_slide_file(slug)
  Slides -> UploadStore : lookup slug
  Slides -> LocalStore : fallback lookup slug
  Slides --> PaxUI : PDF bytes (application/pdf)
  PaxUI -> Pax : render selected PDF
end

== Refresh Loop While Modal Is Open ==

loop every SLIDES_REFRESH_MS
  PaxUI -> Backend : GET /api/slides (cache: no-store)
  Backend --> PaxUI : updated catalog
  PaxUI -> PaxUI : keep selected slug if still present
end

note over PaxUI, Slides
  Slide catalog is global for the session.
  It is NOT filtered by participant UUID.
end note

@enduml
