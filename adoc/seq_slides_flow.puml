@startuml seq_slides_flow
title Slides Catalog Flow - C2 Level

actor "Trainer" as Trainer
database "PPTX Sources\n(watch dir / catalog)" as PptxSources
participant "Slides Daemon\n(slides_daemon.py)" as Daemon
database "Published PDFs\n(materials/slides)" as MaterialsSlides
participant "Workshop Backend\n(FastAPI)" as Backend
participant "Participant Browser UI" as PaxUI
actor "Participant" as Pax

== Automatic Publish Pipeline ==

Trainer -> PptxSources : Save/update .pptx
Daemon -> PptxSources : Poll and detect changed files
Daemon -> Daemon : Convert PPTX -> PDF
Daemon -> MaterialsSlides : Copy PDF (upload_mode=copy)
Daemon -> Backend : POST /api/slides/current
Daemon -> Backend : POST /api/quiz-status {slides:[...]}

== Participant Opens Slides ==

Pax -> PaxUI : Open Slides modal
PaxUI -> Backend : GET /api/slides
Backend -> MaterialsSlides : Scan local PDFs
Backend -> Backend : Merge with state.slides\nand slides_current
Backend --> PaxUI : slides[]

alt no slides
  PaxUI -> Pax : Show "No slides published yet"
else slides available
  PaxUI -> Pax : Populate combo box
  PaxUI -> Backend : GET /api/slides/file/{slug}
  Backend -> MaterialsSlides : Read PDF by slug
  MaterialsSlides --> Backend : PDF bytes
  Backend --> PaxUI : application/pdf
  PaxUI -> Pax : Render preview
end

loop while modal is open
  PaxUI -> Backend : GET /api/slides (no-store)
  Backend -> MaterialsSlides : Refresh local PDFs
  Backend -> Backend : Refresh state.slides\nand slides_current
  Backend --> PaxUI : updated slides[]
end

note over PaxUI, Backend
  Slide catalog is global for the session,
  not filtered by participant UUID.
end note

note over Daemon, MaterialsSlides
  Default publish directory from code:
  PPTX_PUBLISH_DIR = materials/slides
end note

@enduml
