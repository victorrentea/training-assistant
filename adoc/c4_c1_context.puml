@startuml C1_SystemContext
!include <C4/C4_Context>

title Workshop Live Interaction Tool — C1: System Context

LAYOUT_WITH_LEGEND()

Person(victor, "Victor (Host/Trainer)", "Workshop facilitator.")
Person(participant, "Participant", "Audience member.")

System(workshop, "Workshop Tool", "Real-time audience interaction platform.\nHosted on Oracle Cloud.")

System_Ext(audio_hijack, "Audio Hijack", "Captures and transcribes live workshop audio\nto a local file on Victor's Mac.")
System_Ext(claude_api, "Anthropic Claude API", "LLM for quiz generation.")
System_Ext(nominatim, "Nominatim (OpenStreetMap)", "GPS → city + country.")
System_Ext(browser_apis, "Browser APIs", "Geolocation, localStorage, WebSocket.")

Rel(audio_hijack, victor, "Transcript file", "Local file on Mac")
Rel(victor, workshop, "Manages polls and participants", "HTTPS / WebSocket")
Rel(victor, claude_api, "Generates quiz from transcript", "HTTPS REST")
Rel(participant, workshop, "Votes on polls, sees results", "HTTPS / WebSocket")
Rel(participant, nominatim, "Reverse geocodes GPS", "HTTPS REST")
Rel(participant, browser_apis, "Geolocation and local storage", "Browser-internal")

@enduml
