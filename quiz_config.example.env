# Quiz Generator — environment variable template
# Copy to quiz_config.env, fill in values, then run:
#   source quiz_config.env
#   python quiz_generator.py

# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Path to the folder containing transcription files (.txt, .vtt, .srt)
# Zoom saves .vtt files in ~/Documents/Zoom/<meeting-name>/
TRANSCRIPTION_FOLDER=/Users/you/Documents/Zoom/MySession

# URL of the running workshop server (default: http://localhost:8000)
# Change to your OCI server URL when running live
WORKSHOP_SERVER_URL=http://localhost:8000

# How many recent minutes to use for quiz generation (default: 30)
QUIZ_MINUTES=30

# Claude model to use (default: claude-sonnet-4-6)
# Use claude-opus-4-6 for higher quality at higher cost
CLAUDE_MODEL=claude-sonnet-4-6
