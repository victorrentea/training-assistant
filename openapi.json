  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PollCorrect": {
        "properties": {
          "correct_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Correct Ids"
          }
        },
        "type": "object",
        "required": [
          "correct_ids"
        ],
        "title": "PollCorrect"
      },
      "PollCreate": {
        "properties": {
          "question": {
            "type": "string",
            "title": "Question"
          },
          "options": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Options"
          },
          "multi": {
            "type": "boolean",
            "title": "Multi",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "question",
          "options"
        ],
        "title": "PollCreate"
      },
      "PollOpen": {
        "properties": {
          "open": {
            "type": "boolean",
            "title": "Open"
          }
        },
        "type": "object",
        "required": [
          "open"
        ],
        "title": "PollOpen"
      },
      "PollTimer": {
        "properties": {
          "seconds": {
            "type": "integer",
            "title": "Seconds"
          }
        },
        "type": "object",
        "required": [
          "seconds"
        ],
        "title": "PollTimer"
      },
      "QuizPreview": {
        "properties": {
          "question": {
            "type": "string",
            "title": "Question"
          },
          "options": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Options"
          },
          "multi": {
            "type": "boolean",
            "title": "Multi",
            "default": false
          },
          "correct_indices": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Correct Indices",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "question",
          "options"
        ],
        "title": "QuizPreview"
      },
      "QuizRefineRequest": {
        "properties": {
          "target": {
            "type": "string",
            "title": "Target"
          }
        },
        "type": "object",
        "required": [
          "target"
        ],
        "title": "QuizRefineRequest"
      },
      "QuizRequest": {
        "properties": {
          "minutes": {
            "type": "integer",
            "title": "Minutes",
            "default": 30
          }
        },
        "type": "object",
        "title": "QuizRequest"
      },
      "QuizStatus": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "QuizStatus"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
