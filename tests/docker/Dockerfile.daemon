FROM mcr.microsoft.com/playwright/python:v1.50.0-noble

# Install backend + daemon + test dependencies
RUN pip install \
    fastapi \
    "uvicorn[standard]" \
    python-multipart \
    prometheus-fastapi-instrumentator \
    websockets \
    anthropic \
    pytest \
    pytest-bdd \
    pytest-playwright \
    playwright==1.50.0

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Copy the full application codebase
COPY app/ /app/

# Copy test page objects (reused from existing e2e suite)
COPY tests/pages/ /app/tests/pages/

# Copy test files
WORKDIR /tests
COPY tests/docker/test_daemon_connected.py .
COPY tests/docker/test_poll_flow.py .
COPY tests/docker/test_slides_view.py .
COPY tests/docker/test_follow_me.py .
COPY tests/docker/test_participant_interactions.py .
COPY tests/docker/test_qa_wordcloud.py .
COPY tests/docker/test_integrations.py .
COPY tests/docker/test_high_value.py .
COPY tests/docker/test_poll_advanced.py .
COPY tests/docker/test_ui_interactions.py .
COPY tests/docker/test_slides_advanced.py .
COPY tests/docker/test_regressions.py .
COPY tests/docker/test_unique_avatars.py .
COPY tests/docker/test_follow_mode_slow_drive.py .
COPY tests/docker/features/ ./features/
COPY tests/docker/step_defs/ ./step_defs/
COPY tests/docker/generate_fixture_pdfs.py .
COPY tests/docker/mock_drive_server.py .
COPY tests/docker/start_hermetic.sh /start_hermetic.sh
RUN chmod +x /start_hermetic.sh

ENTRYPOINT ["/start_hermetic.sh"]
CMD ["-v", "--tb=long", "-s", "--durations=0", "-m", "not nightly"]
