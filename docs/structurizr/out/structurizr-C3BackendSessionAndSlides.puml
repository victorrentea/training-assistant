@startuml
title <size:24>Component View: Workshop Live Interaction Tool - FastAPI Backend</size>\n<size:24>Session, snapshot, slides, upload, and summary slice.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System_Boundary("WorkshopLiveInteractionTool_boundary", "Workshop Live Interaction Tool", $tags="") {
  Container_Boundary("WorkshopLiveInteractionTool.FastAPIBackend_boundary", "FastAPI Backend", $tags="") {
    Component(WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Core Platform", $techn="core/*", $descr="AppState, auth, metrics, versioning, session guards, and messaging registry.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.SummaryRouter, "Summary Router", $techn="features/summary/*", $descr="Summaries, notes, transcript status, and token usage.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.SessionRouter, "Session Router", $techn="features/session/*", $descr="Global and session-scoped lifecycle, sync, snapshots, and timing events.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.SnapshotRouter, "Snapshot Router", $techn="features/snapshot/*", $descr="Diagnostic state snapshot and restore endpoints.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.SlidesRouter, "Slides Router", $techn="features/slides/*", $descr="Slides publishing, public file serving, upload, and catalog management.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.UploadRouter, "Upload Router", $techn="features/upload/*", $descr="Participant and host file upload endpoints.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.PagesRouter, "Pages Router", $techn="features/pages/*", $descr="Landing, participant, host, and notes pages.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.InternalRouter, "Internal Router", $techn="features/internal/*", $descr="Daemon-facing internal file-management endpoints.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.TranscriptionLanguageRouter, "Transcription Language Router", $techn="features/transcription_language/*", $descr="Global transcription language endpoint.", $tags="", $link="")
  }

  Container(WorkshopLiveInteractionTool.TrainingDaemon, "Training Daemon", $techn="Python 3.12 CLI", $descr="Background worker running on the host machine.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.ParticipantSPA, "Participant SPA", $techn="HTML/CSS/JavaScript", $descr="Participant-facing UI served from static files.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.HostSPA, "Host SPA", $techn="HTML/CSS/JavaScript", $descr="Host control panel served from static files.", $tags="", $link="")
}

Rel(WorkshopLiveInteractionTool.FastAPIBackend.InternalRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Uses shared backend state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.TranscriptionLanguageRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Reads current session context", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.UploadRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Associates uploads with active state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.PagesRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Reads active mode and session state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.SummaryRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Reads and updates summaries and notes", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.SessionRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Serializes and restores session state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.SnapshotRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Serializes and restores diagnostic snapshots", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.SlidesRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Stores slide catalog and current slide", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.FastAPIBackend.PagesRouter, "Loads participant and notes pages", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.FastAPIBackend.SummaryRouter, "Reads public notes and summaries", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.FastAPIBackend.SlidesRouter, "Reads public slides", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.FastAPIBackend.UploadRouter, "Uploads participant files", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.PagesRouter, "Loads host page", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.SummaryRouter, "Reads notes and summaries", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.SlidesRouter, "Publishes current slides", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.SessionRouter, "Controls session lifecycle", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.SnapshotRouter, "Requests snapshot/restore", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.UploadRouter, "Uploads host files", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.TranscriptionLanguageRouter, "Changes transcription language", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml