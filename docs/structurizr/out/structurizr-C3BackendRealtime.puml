@startuml
title <size:24>Component View: Workshop Live Interaction Tool - FastAPI Backend</size>\n<size:24>Realtime-focused backend slice.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System_Boundary("WorkshopLiveInteractionTool_boundary", "Workshop Live Interaction Tool", $tags="") {
  Container_Boundary("WorkshopLiveInteractionTool.FastAPIBackend_boundary", "FastAPI Backend", $tags="") {
    Component(WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Core Platform", $techn="core/*", $descr="AppState, auth, metrics, versioning, session guards, and messaging registry.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.WSRouter, "WS Router", $techn="features/ws/*", $descr="Host, participant, overlay, and daemon WebSocket endpoints plus proxy bridge.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.PollRouter, "Poll Router", $techn="features/poll/*", $descr="Poll lifecycle, status, correct answers, scoring, and public helpers.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.QARouter, "Q&A Router", $techn="features/qa/*", $descr="Question edit, delete, answer, and clear lifecycle.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.WordCloudRouter, "Word Cloud Router", $techn="features/wordcloud/*", $descr="Topic changes and reset operations.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.CodeReviewRouter, "Code Review Router", $techn="features/codereview/*", $descr="Snippet lifecycle, selections, and line confirmation.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.DebateRouter, "Debate Router", $techn="features/debate/*", $descr="Debate phases, AI request lifecycle, and round orchestration.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.LeaderboardRouter, "Leaderboard Router", $techn="features/leaderboard/*", $descr="Leaderboard reveal and score reset endpoints.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.FastAPIBackend.ActivityRouter, "Activity Router", $techn="features/activity/*", $descr="Switches the currently active participant experience.", $tags="", $link="")
  }

  Container(WorkshopLiveInteractionTool.ParticipantSPA, "Participant SPA", $techn="HTML/CSS/JavaScript", $descr="Participant-facing UI served from static files.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.HostSPA, "Host SPA", $techn="HTML/CSS/JavaScript", $descr="Host control panel served from static files.", $tags="", $link="")
}

Rel(WorkshopLiveInteractionTool.FastAPIBackend.WSRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Builds and broadcasts state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.PollRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Mutates poll state and scores", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.QARouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Mutates Q&A state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.WordCloudRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Mutates word cloud state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.CodeReviewRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Mutates code review state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.DebateRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Mutates debate state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.LeaderboardRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Updates leaderboard visibility and scores", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.FastAPIBackend.ActivityRouter, WorkshopLiveInteractionTool.FastAPIBackend.CorePlatform, "Updates current activity", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.FastAPIBackend.WSRouter, "Connects as participant", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.FastAPIBackend.PollRouter, "Reads status and identity helpers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.WSRouter, "Connects as host", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.PollRouter, "Creates polls and manages poll state", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.QARouter, "Moderates questions", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.WordCloudRouter, "Sets topic and clears cloud", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.CodeReviewRouter, "Manages code review activity", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.DebateRouter, "Controls debate phases and cleanup", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.LeaderboardRouter, "Reveals leaderboard", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.FastAPIBackend.ActivityRouter, "Switches activity", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml